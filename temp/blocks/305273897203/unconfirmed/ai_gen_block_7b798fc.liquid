{% doc %}
  @prompt
    i want to generate a section that is similar to a border, but i want it to be an colorable svg of grass flat vector, fulscreen
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-grass-border-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-grass-border-svg-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: {{ block.settings.height }}px;
  }

  .ai-grass-border-svg-{{ ai_gen_id }} path {
    fill: {{ block.settings.grass_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-grass-border-svg-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }
{% endstyle %}

<grass-border-{{ ai_gen_id }} class="ai-grass-border-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <svg
    class="ai-grass-border-svg-{{ ai_gen_id }}"
    viewBox="0 0 1440 120"
    preserveAspectRatio="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path d="M0,60 Q10,45 20,60 T40,60 Q50,45 60,60 T80,60 Q90,45 100,60 T120,60 Q130,45 140,60 T160,60 Q170,45 180,60 T200,60 Q210,45 220,60 T240,60 Q250,45 260,60 T280,60 Q290,45 300,60 T320,60 Q330,45 340,60 T360,60 Q370,45 380,60 T400,60 Q410,45 420,60 T440,60 Q450,45 460,60 T480,60 Q490,45 500,60 T520,60 Q530,45 540,60 T560,60 Q570,45 580,60 T600,60 Q610,45 620,60 T640,60 Q650,45 660,60 T680,60 Q690,45 700,60 T720,60 Q730,45 740,60 T760,60 Q770,45 780,60 T800,60 Q810,45 820,60 T840,60 Q850,45 860,60 T880,60 Q890,45 900,60 T920,60 Q930,45 940,60 T960,60 Q970,45 980,60 T1000,60 Q1010,45 1020,60 T1040,60 Q1050,45 1060,60 T1080,60 Q1090,45 1100,60 T1120,60 Q1130,45 1140,60 T1160,60 Q1170,45 1180,60 T1200,60 Q1210,45 1220,60 T1240,60 Q1250,45 1260,60 T1280,60 Q1290,45 1300,60 T1320,60 Q1330,45 1340,60 T1360,60 Q1370,45 1380,60 T1400,60 Q1410,45 1420,60 T1440,60 L1440,120 L0,120 Z"></path>
  </svg>
</grass-border-{{ ai_gen_id }}>

<script>
  (function() {
    class GrassBorder{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.updateGrassPattern();
      }

      updateGrassPattern() {
        const svg = this.querySelector('.ai-grass-border-svg-{{ ai_gen_id }}');
        if (!svg) return;

        svg.setAttribute('aria-hidden', 'true');
      }
    }

    customElements.define('grass-border-{{ ai_gen_id }}', GrassBorder{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Grass border",
  "tag": null,
  "class": "grass-border-block",
  "settings": [
    {
      "type": "header",
      "content": "Grass style"
    },
    {
      "type": "color",
      "id": "grass_color",
      "label": "Grass color",
      "default": "#22c55e"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Height (desktop)",
      "min": 40,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Height (mobile)",
      "min": 30,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Grass border"
    }
  ]
}
{% endschema %}
