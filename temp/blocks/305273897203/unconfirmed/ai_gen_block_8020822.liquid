{% doc %}
  @prompt
    i want to generate a section that is similar to a border, but i want it to be an colorable svg of grass flat vector, fulscreen, make it look more like blades of grass with different variations of shape, height, direction, etc, add more configurable parameters
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-grass-border-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
  }

  .ai-grass-border-svg-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    height: {{ block.settings.height }}px;
    {% if block.settings.flip_vertical %}
      transform: scaleY(-1);
    {% endif %}
  }

  .ai-grass-border-blade-{{ ai_gen_id }} {
    fill: {{ block.settings.grass_color }};
    opacity: {{ block.settings.opacity | divided_by: 100.0 }};
    transition: fill 0.3s ease;
  }

  .ai-grass-border-blade-light-{{ ai_gen_id }} {
    fill: {% if block.settings.enable_gradient %}{{ block.settings.grass_color_light }}{% else %}{{ block.settings.grass_color }}{% endif %};
    opacity: {{ block.settings.opacity | divided_by: 100.0 | times: 0.7 }};
    transition: fill 0.3s ease;
  }

  .ai-grass-border-blade-dark-{{ ai_gen_id }} {
    fill: {% if block.settings.enable_gradient %}{{ block.settings.grass_color_dark }}{% else %}{{ block.settings.grass_color }}{% endif %};
    opacity: {{ block.settings.opacity | divided_by: 100.0 | times: 1.3 }};
    transition: fill 0.3s ease;
  }

  {% if block.settings.enable_animation %}
    .ai-grass-border-svg-{{ ai_gen_id }} path {
      animation: ai-grass-sway-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
      transform-origin: bottom center;
    }

    .ai-grass-border-svg-{{ ai_gen_id }} path:nth-child(2n) {
      animation-delay: 0.2s;
    }

    .ai-grass-border-svg-{{ ai_gen_id }} path:nth-child(3n) {
      animation-delay: 0.4s;
    }

    @keyframes ai-grass-sway-{{ ai_gen_id }} {
      0%, 100% {
        transform: skewX(0deg);
      }
      25% {
        transform: skewX({{ block.settings.animation_intensity }}deg);
      }
      75% {
        transform: skewX(-{{ block.settings.animation_intensity }}deg);
      }
    }
  {% endif %}

  @media screen and (max-width: 749px) {
    .ai-grass-border-svg-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }
  }
{% endstyle %}

