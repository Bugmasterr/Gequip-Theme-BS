{% doc %}
  @prompt
    add a bee (the bee emoji) that flies around in a random twirly pattern and repeats, similar to a marquee but an animated bee emoji, make him fly right to left instead of left to right and tighten the vertical range in which the bee can fly and smooth the curves/movement interpolation 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-flying-bee-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: {{ block.settings.z_index }};
    overflow: hidden;
  }

  .ai-flying-bee__emoji-{{ ai_gen_id }} {
    position: absolute;
    font-size: {{ block.settings.bee_size }}px;
    animation: ai-flying-bee-path-{{ ai_gen_id }} {{ block.settings.animation_duration }}s ease-in-out infinite;
  }

  @keyframes ai-flying-bee-path-{{ ai_gen_id }} {
    0% {
      left: 110%;
      top: 45%;
      transform: rotate(0deg) scaleX(-1);
    }
    5% {
      left: 102%;
      top: 42%;
      transform: rotate(-8deg) scaleX(-1);
    }
    10% {
      left: 95%;
      top: 48%;
      transform: rotate(5deg) scaleX(-1);
    }
    15% {
      left: 88%;
      top: 44%;
      transform: rotate(-6deg) scaleX(-1);
    }
    20% {
      left: 82%;
      top: 50%;
      transform: rotate(7deg) scaleX(-1);
    }
    25% {
      left: 75%;
      top: 46%;
      transform: rotate(-5deg) scaleX(-1);
    }
    30% {
      left: 68%;
      top: 52%;
      transform: rotate(8deg) scaleX(-1);
    }
    35% {
      left: 62%;
      top: 48%;
      transform: rotate(-7deg) scaleX(-1);
    }
    40% {
      left: 55%;
      top: 54%;
      transform: rotate(6deg) scaleX(-1);
    }
    45% {
      left: 48%;
      top: 50%;
      transform: rotate(-8deg) scaleX(-1);
    }
    50% {
      left: 42%;
      top: 56%;
      transform: rotate(7deg) scaleX(-1);
    }
    55% {
      left: 35%;
      top: 52%;
      transform: rotate(-6deg) scaleX(-1);
    }
    60% {
      left: 28%;
      top: 58%;
      transform: rotate(8deg) scaleX(-1);
    }
    65% {
      left: 22%;
      top: 54%;
      transform: rotate(-7deg) scaleX(-1);
    }
    70% {
      left: 15%;
      top: 60%;
      transform: rotate(6deg) scaleX(-1);
    }
    75% {
      left: 10%;
      top: 56%;
      transform: rotate(-5deg) scaleX(-1);
    }
    80% {
      left: 5%;
      top: 62%;
      transform: rotate(7deg) scaleX(-1);
    }
    85% {
      left: 2%;
      top: 58%;
      transform: rotate(-6deg) scaleX(-1);
    }
    90% {
      left: -2%;
      top: 64%;
      transform: rotate(5deg) scaleX(-1);
    }
    95% {
      left: -4%;
      top: 60%;
      transform: rotate(-4deg) scaleX(-1);
    }
    100% {
      left: -10%;
      top: 65%;
      transform: rotate(0deg) scaleX(-1);
    }
  }
{% endstyle %}

<div class="ai-flying-bee-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-flying-bee__emoji-{{ ai_gen_id }}">🐝</div>
</div>

{% schema %}
{
  "name": "Flying bee",
  "settings": [
    {
      "type": "range",
      "id": "bee_size",
      "label": "Bee size",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Animation duration",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 15
    },
    {
      "type": "range",
      "id": "z_index",
      "label": "Layer position",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 10
    }
  ],
  "presets": [
    {
      "name": "Flying bee"
    }
  ]
}
{% endschema %}
