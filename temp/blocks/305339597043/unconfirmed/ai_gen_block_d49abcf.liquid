{% doc %}
  @prompt
    Enhance the existing Flying bee block (block ID: ai_gen_block_ef2b355) with more configurable settings. Add schema settings for: bee color or emoji choice, number of bees, opacity/transparency control, animation style options (e.g., zigzag, loop, float), and a toggle to show/hide on mobile devices. Keep the existing bee size and animation duration settings.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-flying-bee-container-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9999;
    overflow: hidden;
  }

  {% if block.settings.hide_on_mobile %}
    @media screen and (max-width: 749px) {
      .ai-flying-bee-container-{{ ai_gen_id }} {
        display: none;
      }
    }
  {% endif %}

  .ai-flying-bee-{{ ai_gen_id }} {
    position: absolute;
    font-size: {{ block.settings.bee_size }}px;
    opacity: {{ block.settings.bee_opacity | divided_by: 100.0 }};
    pointer-events: none;
    will-change: transform;
  }

  {% if block.settings.animation_style == 'zigzag' %}
    @keyframes ai-flying-bee-zigzag-{{ ai_gen_id }} {
      0% {
        transform: translate(0, 0) rotate(0deg);
      }
      25% {
        transform: translate(100px, 25vh) rotate(10deg);
      }
      50% {
        transform: translate(-50px, 50vh) rotate(-10deg);
      }
      75% {
        transform: translate(80px, 75vh) rotate(5deg);
      }
      100% {
        transform: translate(0, 100vh) rotate(0deg);
      }
    }
  {% elsif block.settings.animation_style == 'loop' %}
    @keyframes ai-flying-bee-loop-{{ ai_gen_id }} {
      0% {
        transform: translate(0, 0) rotate(0deg);
      }
      25% {
        transform: translate(150px, 20vh) rotate(90deg);
      }
      50% {
        transform: translate(150px, 40vh) rotate(180deg);
      }
      75% {
        transform: translate(0, 60vh) rotate(270deg);
      }
      100% {
        transform: translate(0, 80vh) rotate(360deg);
      }
    }
  {% elsif block.settings.animation_style == 'float' %}
    @keyframes ai-flying-bee-float-{{ ai_gen_id }} {
      0%, 100% {
        transform: translate(0, 0) rotate(-5deg);
      }
      25% {
        transform: translate(30px, -20px) rotate(5deg);
      }
      50% {
        transform: translate(-20px, 10px) rotate(-3deg);
      }
      75% {
        transform: translate(25px, -15px) rotate(3deg);
      }
    }
  {% else %}
    @keyframes ai-flying-bee-straight-{{ ai_gen_id }} {
      0% {
        transform: translate(0, -100px) rotate(0deg);
      }
      100% {
        transform: translate(0, calc(100vh + 100px)) rotate(0deg);
      }
    }
  {% endif %}
{% endstyle %}

<div class="ai-flying-bee-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% for i in (1..block.settings.number_of_bees) %}
    <div
      class="ai-flying-bee-{{ ai_gen_id }} ai-flying-bee-{{ ai_gen_id }}-{{ i }}"
      data-bee-index="{{ i }}"
    >
      {% if block.settings.bee_type == 'emoji' %}
        {{ block.settings.bee_emoji }}
      {% else %}
        <svg width="1em" height="1em" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="12" cy="14" rx="6" ry="8" fill="{{ block.settings.bee_color }}" stroke="#000" stroke-width="0.5"/>
          <ellipse cx="12" cy="10" rx="4" ry="5" fill="{{ block.settings.bee_color }}" stroke="#000" stroke-width="0.5"/>
          <circle cx="10.5" cy="9" r="1" fill="#000"/>
          <circle cx="13.5" cy="9" r="1" fill="#000"/>
          <path d="M 5 10 Q 3 8 4 6" stroke="#000" stroke-width="0.8" fill="none"/>
          <path d="M 19 10 Q 21 8 20 6" stroke="#000" stroke-width="0.8" fill="none"/>
          <rect x="10" y="12" width="4" height="1" fill="#000"/>
          <rect x="10" y="15" width="4" height="1" fill="#000"/>
          <rect x="10" y="18" width="4" height="1" fill="#000"/>
        </svg>
      {% endif %}
    </div>
  {% endfor %}
</div>

<script>
  (function() {
    class FlyingBees{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.bees = [];
        this.animationStyle = '{{ block.settings.animation_style }}';
        this.animationDuration = {{ block.settings.animation_duration }};
      }

      connectedCallback() {
        this.bees = Array.from(this.querySelectorAll('.ai-flying-bee-{{ ai_gen_id }}'));
        this.initializeBees();
      }

      initializeBees() {
        this.bees.forEach((bee, index) => {
          const delay = (index * (this.animationDuration / this.bees.length));
          const startX = Math.random() * (window.innerWidth - 100);
          
          bee.style.left = startX + 'px';
          
          if (this.animationStyle === 'float') {
            bee.style.top = (Math.random() * 80 + 10) + '%';
            bee.style.animation = `ai-flying-bee-float-{{ ai_gen_id }} ${this.animationDuration}s ease-in-out ${delay}s infinite`;
          } else if (this.animationStyle === 'zigzag') {
            bee.style.top = '-100px';
            bee.style.animation = `ai-flying-bee-zigzag-{{ ai_gen_id }} ${this.animationDuration}s linear ${delay}s infinite`;
          } else if (this.animationStyle === 'loop') {
            bee.style.top = '-100px';
            bee.style.animation = `ai-flying-bee-loop-{{ ai_gen_id }} ${this.animationDuration}s ease-in-out ${delay}s infinite`;
          } else {
            bee.style.top = '-100px';
            bee.style.animation = `ai-flying-bee-straight-{{ ai_gen_id }} ${this.animationDuration}s linear ${delay}s infinite`;
          }
        });
      }
    }

    customElements.define('flying-bees-{{ ai_gen_id }}', FlyingBees{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Flying bee",
  "settings": [
    {
      "type": "header",
      "content": "Bee appearance"
    },
    {
      "type": "radio",
      "id": "bee_type",
      "label": "Bee type",
      "options": [
        {
          "value": "svg",
          "label": "SVG bee"
        },
        {
          "value": "emoji",
          "label": "Emoji"
        }
      ],
      "default": "svg"
    },
    {
      "type": "color",
      "id": "bee_color",
      "label": "Bee color",
      "default": "#FFD700",
      "info": "Only applies to SVG bee type"
    },
    {
      "type": "text",
      "id": "bee_emoji",
      "label": "Emoji",
      "default": "🐝",
      "info": "Only applies to Emoji type"
    },
    {
      "type": "range",
      "id": "bee_size",
      "label": "Bee size",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "bee_opacity",
      "label": "Opacity",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 80
    },
    {
      "type": "header",
      "content": "Bee behavior"
    },
    {
      "type": "range",
      "id": "number_of_bees",
      "label": "Number of bees",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "animation_style",
      "label": "Animation style",
      "options": [
        {
          "value": "straight",
          "label": "Straight"
        },
        {
          "value": "zigzag",
          "label": "Zigzag"
        },
        {
          "value": "loop",
          "label": "Loop"
        },
        {
          "value": "float",
          "label": "Float"
        }
      ],
      "default": "zigzag"
    },
    {
      "type": "range",
      "id": "animation_duration",
      "label": "Animation duration",
      "min": 5,
      "max": 30,
      "step": 1,
      "unit": "s",
      "default": 15
    },
    {
      "type": "header",
      "content": "Visibility"
    },
    {
      "type": "checkbox",
      "id": "hide_on_mobile",
      "label": "Hide on mobile",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Flying bee"
    }
  ]
}
{% endschema %}
